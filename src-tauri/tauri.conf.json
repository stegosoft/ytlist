{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ytlist",
  "version": "0.1.0",
  "identifier": "com.ytlist.app",
  "build": {},
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "cli": {
      "description": "Extract all video URLs from a YouTube playlist in order",
      "args": [
        {
          "name": "playlist",
          "short": "p",
          "description": "YouTube playlist URL (required)",
          "takesValue": true,
          "required": true
        },
        {
          "name": "out",
          "short": "o",
          "description": "Output file path (optional – defaults to stdout)",
          "takesValue": true,
          "required": false
        }
      ]
    }
  }
}
